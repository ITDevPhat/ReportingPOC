{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ReportingPOC;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ReportingEngine": {
    "MaxRows": 10000,
    "DefaultLimit": 100,
    "CommandTimeoutSeconds": 60,
    "MaxSelectedFields": 50,
    "MaxMetrics": 20,
    "MaxFilters": 30,
    "MaxGroupByFields": 20,
    "EnableSqlPreview": true,
    "EnableBackgroundWorker": true,
    "BackgroundWorkerIntervalSeconds": 3,
    "BackgroundWorkerBatchSize": 5,
    "EnableQueryCaching": true,
    "QueryCacheTtlMinutes": 30
  },
  "ArtifactStorage": {
    "Provider": "Local",
    "LocalPath": "artifacts"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
